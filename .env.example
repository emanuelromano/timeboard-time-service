# =========================================================
# TimeBoard Time Service (TBTS)
# Example Environment Configuration
#
# Copy this file to ".env" and adjust the values as needed.
# =========================================================

# ---------------------------------------------------------
# Network
# ---------------------------------------------------------

TBTS_HOST=127.0.0.1
TBTS_PORT=8000

# ---------------------------------------------------------
# Service
# ---------------------------------------------------------

TBTS_SERVICE_NAME=TimeBoard Time Service
TBTS_SERVICE_SHORT_NAME=TBTS
TBTS_SERVICE_VERSION=1.0.1
TBTS_API_VERSION=v1
TBTS_SERVICE_DESCRIPTION=Lightweight HTTP time service for legacy Palm OS devices.

# ---------------------------------------------------------
# Repository
# ---------------------------------------------------------

TBTS_PROJECT_URL=https://github.com/emanuelromano/timeboard-time-service
TBTS_LICENSE=MIT